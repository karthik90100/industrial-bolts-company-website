	100% {transform: translateY(0)}
}

</style>
<style class="bv-critical-css" bv-identifier="https://royalanchors.com/wp-content/plugins/codevz-plus/wpbakery/assets/css/gallery.css?ver=5.6" id="cz_gallery-css">
@keyframes xtraGridShineDef {100% {left: -125%}}
@keyframes xtraGridShine {100% {left: 125%}}
@keyframes rotateInfinite {
	from {transform: rotate(0deg)}
	to {transform: rotate(360deg)}
}
@keyframes gridFadeIn {100% {opacity: 1}}
@keyframes gridMoveUp {100% {transform: translateY(0);opacity: 1}}
@keyframes gridMoveDown {100% {transform: translateY(0);opacity: 1}}
@keyframes gridMoveLeft {100% {transform: translateX(0);opacity: 1}}
@keyframes gridMoveRight {100% {transform: translateX(0);opacity: 1}}
@keyframes gridZoomIn {100% {transform: scale(1);opacity: 1}}
@keyframes gridZoomOut {100% {transform: scale(1);opacity: 1}}
@keyframes gridFallPerspective {100% {transform: translateZ(0px) translateY(0px) rotateX(0deg);opacity: 1}}
@keyframes gridSlant {100% {transform: rotateX(0deg);opacity: 1}}
@keyframes gridHelix {100% {transform: rotateY(0deg);opacity: 1}}

</style>
