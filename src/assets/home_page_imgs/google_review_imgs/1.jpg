<script type="bv_inline_delayed_js" bv_unique_id="MyoL0WPSoW26oFBGIxsc" id="unlimited-elements-scripts" defer="1" data-cfasync="false" bv_inline_delayed="1" async="">/* List Marquee scripts: */ 

jQuery(document).ready(function(){

   var objListMarquee = jQuery('#uc_list_marquee_elementor_280296f');
   
   //find all items and clone them 9 times
   function cloneItems(){
   
    var objItemsWrapper = objListMarquee.find('.ue-marquee-content');
   	
    for(let i=0; i<3; i++){
      
    	var objItemsCloned = objListMarquee.find('.ue-marquee-tag').clone();
      
    	objItemsWrapper.append(objItemsCloned);
    
    } 
   
   }
   
   cloneItems();
   
   objListMarquee.on("uc_ajax_refreshed",function(){
     	cloneItems();
   });

});

