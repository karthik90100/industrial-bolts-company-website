#uc_list_marquee_elementor_280296f {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  overflow: hidden;
  direction:ltr;
}
#uc_list_marquee_elementor_280296f .ue-marquee-content {
  display: flex;
  will-change: transform;
  animation: marqueeuc_list_marquee_elementor_280296f 45s linear infinite running;
  animation-delay: 250ms;
}
#uc_list_marquee_elementor_280296f .ue-marquee-tag {
  width: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  white-space: nowrap;
  direction:ltr;
}
#uc_list_marquee_elementor_280296f .ue-marquee-tag a {
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  text-stroke: 0px ;
}
#uc_list_marquee_elementor_280296f .ue-marquee-tag-icon {
flex-grow: 0;   flex-shrink: 0;
  line-height:1em;
}
#uc_list_marquee_elementor_280296f .ue_marq_text_wrap{
  display:flex;
  flex-direction: row;
  align-items: center;
}
@keyframes marqueeuc_list_marquee_elementor_280296f {
  0% {
 	-webkit-transform: translateX(0);
    transform: translateX(0);
  }
  100% {
    -webkit-transform: translate(-50%);
    transform: translate(-50%);
  }
}
@keyframes marquee-reverseuc_list_marquee_elementor_280296f {
  0% {
 	-webkit-transform: translateX(-50%);
    transform: translateX(-50%);
  }
  100% {
    -webkit-transform: translate(0%);
    transform: translate(0%);
  }
}

