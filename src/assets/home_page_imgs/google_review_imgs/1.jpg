<style class="bv-critical-css" bv-identifier="https://royalanchors.com/wp-content/plugins/codevz-plus/assets/css/elementor.css?ver=5.6" id="xtra-elementor-front-css">
.codevz-con-stretch-yes:not(header *):not(footer *),
.elementor-section-stretched:not(header *):not(footer *) {
	position: relative;
	right: auto !important;
	left: -60px !important;
	width: calc(100% + 120px) !important;
	max-width: calc(100% + 120px) !important
}
.layout_ .codevz-con-stretch-yes:not(header *):not(footer *),
.layout_ .elementor-section-stretched:not(header *):not(footer *) {
	position: relative;
	right: auto !important;
