<style type="text/css">/* widget: Flip Box */

/* elementor container support */
.e-con-inner>.elementor-widget-ucaddon_flip_box, .e-con>.elementor-widget-ucaddon_flip_box {
    width: var(--container-widget-width);
    --flex-grow: var(--container-widget-flex-grow);
}

#uc_flip_box_elementor_348baf2 .ue-flip-box__panel.ue-flip-box__panel--front,
#uc_flip_box_elementor_348baf2 .ue-flip-box__panel.ue-flip-box__panel--back {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden; 
}


#uc_flip_box_elementor_348baf2 .ue-flip-box__panel--back .ue_btn{
	display: inline-block;
}
 

	        #uc_flip_box_elementor_348baf2 .ue-flip-box__panel__wrapper { 
            transform: translateZ(90px) scale(0.91);
            transform-style: preserve-3d;
        }	
    





#uc_flip_box_elementor_348baf2 .ue-flip-box__panel--front-overlay, #uc_flip_box_elementor_348baf2 .ue-flip-box__panel--back-overlay
{
  position:absolute;
  top:0;
  bottom:0;
  right:0;
  left:0;
  z-index:-1;
}



</style>

<div id="uc_flip_box_elementor_348baf2" class="ue-flip-box" data-id="uc_flip_box_elementor_348baf2" data-closeonbody="false">
  
